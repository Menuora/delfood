rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Settings Collection ──
    // Anyone can read the settings (restaurant name, hours, maps, homepage images).
    // Only authenticated admin users can modify settings.
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Images/Gallery Collection ──
    // Anyone can read image metadata to render the menu and gallery sections.
    // Only authenticated admin users can add or delete images.
    match /images/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Bookings Collection ──
    // Anyone can submit a booking request (create operation) from the public form.
    // Only authenticated admin users can read, update, or delete booking requests.
    match /bookings/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
